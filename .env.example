# Server Configuration
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional: set to true if your Supabase columns use snake_case instead of the old camelCase document shape
SUPABASE_USE_SNAKE_CASE=false
# Optional: set to id if your tables use id instead of _id
SUPABASE_ID_COLUMN=_id
# Optional table overrides if your table names differ
# SUPABASE_TABLE_USERS=users
# SUPABASE_TABLE_INVENTORY=inventory
# SUPABASE_TABLE_SITES=sites
# SUPABASE_TABLE_TRANSACTIONS=transactions
# SUPABASE_TABLE_DELIVERIES=deliveries
# SUPABASE_TABLE_ATTENDANCE=attendance
# SUPABASE_TABLE_NOTIFICATIONS=notifications
# SUPABASE_TABLE_FAVORITES=favorites
# SUPABASE_TABLE_LOGS=logs
# SUPABASE_TABLE_ACTIVITIES=activities
# SUPABASE_TABLE_APP_CONFIG=app_config

# JWT Configuration
# SECURITY: Generate a strong random secret for production
# Example: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Cloudinary (CDN)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OneSignal Push Notifications
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
