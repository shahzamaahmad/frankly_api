

# Server Configuration
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Required for Supabase Auth sign-in / refresh flows
SUPABASE_ANON_KEY=
# Optional: only needed if you want username-based auth without real emails
SUPABASE_AUTH_FALLBACK_EMAIL_DOMAIN=users.yourcompany.local
# Snake_case and UUID ids match the current SQL schema by default
SUPABASE_USE_SNAKE_CASE=true
SUPABASE_ID_COLUMN=id
# Optional table overrides if your table names differ
# SUPABASE_TABLE_USERS=users
# SUPABASE_TABLE_INVENTORY=inventory
# SUPABASE_TABLE_SITES=sites
# SUPABASE_TABLE_TRANSACTIONS=transactions
# SUPABASE_TABLE_DELIVERIES=deliveries
# SUPABASE_TABLE_ATTENDANCE=attendance
# SUPABASE_TABLE_NOTIFICATIONS=notifications
# SUPABASE_TABLE_FAVORITES=favorites
# SUPABASE_TABLE_LOGS=logs
# SUPABASE_TABLE_ACTIVITIES=activities
# SUPABASE_TABLE_APP_CONFIG=app_config

# JWT Configuration
# SECURITY: Generate a strong random secret for production
# Example: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Cloudinary (CDN)
CLOUDINARY_URL=
# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_ASSISTANT_MODEL=gpt-5
OPENAI_TRANSACTION_MODEL=gpt-5

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://franklybuilt.web.app,https://whole-cloth-373116.web.app

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OneSignal Push Notifications
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
